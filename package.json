{
  "name": "z80-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first Z80 assembly IDE, assembler, and simulator.",
  "author": "VVeb1250",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop": "npm run build && electron .",
    "lint": "oxlint",
    "package": "npm run build && electron-builder --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "test": "node --test test/artifacts.test.ts test/editor-options.test.ts test/editor-support.test.ts test/editor-theme.test.ts test/electron-server.test.cjs test/instructions.test.ts test/settings.test.ts test/tab-action.test.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "dockview": "^7.0.3",
    "dockview-react": "^7.0.3",
    "emulators": "^8.4.1",
    "js-dos": "^8.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.9"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "io.github.vveb1250.z80workspace",
    "productName": "Z80 Workspace",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${name}-setup-${version}-${os}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${name}-portable-${version}-${os}-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "VVeb1250",
      "repo": "z80-workspace"
    }
  }
}
